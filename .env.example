# Euclid's Window Environment Variables

# Database (SQLite for local, Postgres for production)
DATABASE_URL=sqlite:///./euclids_window.db
# DATABASE_URL=postgresql://user:password@host:5432/euclids_window

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRE_HOURS=24

# Local LLM (Ollama)
# LOCAL_LLM_BASE_URL=http://localhost:11434
# LOCAL_LLM_MODEL=qwen2.5:1.5b
# Per-task model routing (optional; falls back to LOCAL_LLM_MODEL)
# LOCAL_CODEGEN_MODEL=qwen2.5-coder:7b   # Manim/matplotlib code generation
# LOCAL_FAST_MODEL=qwen2.5:1.5b          # quick JSON extraction tasks
# LOCAL_POLYA_MODEL=qwen3:4b-instruct        # Polya problem-solving coach (needs real math judging)
# LOCAL_POLYA_OLYMPIAD_MODEL=qwen3:8b        # stronger judging for olympiad-difficulty sessions
# Use the host's Metal-accelerated Ollama from Docker (host must set OLLAMA_HOST=0.0.0.0):
# LOCAL_LLM_BASE_URL=http://host.docker.internal:11434

# Debug mode
DEBUG=false
